# ------------------------------------------------------------------
# DoctorFill - Backend Environment Variables
# ------------------------------------------------------------------
# Copier ce fichier en .env et adapter les valeurs.
#   cp .env.example .env
# ------------------------------------------------------------------

# --- URLs des services (docker-compose utilise les noms de containers)
MARKER_URL=http://marker_ocr:8082
TEI_URL=http://tei:8081
VLLM_URL=http://vllm:8000/v1
VLLM_MODEL_NAME=Qwen/Qwen2.5-14B-Instruct-AWQ

# --- Modeles TEI
EMBED_MODEL_NAME=BAAI/bge-m3
RERANK_MODEL_NAME=BAAI/bge-reranker-v2-m3

# --- CORS (origines autorisees, separees par des virgules)
# Dev  : ALLOWED_ORIGINS=*
# Prod : ALLOWED_ORIGINS=https://doctorfill.ch,https://www.doctorfill.ch
ALLOWED_ORIGINS=*

# --- Cleanup automatique (duree de retention des jobs termines, en secondes)
JOB_RETENTION_SECONDS=3600
